{
  "$schema": "https://opencode.ai/config.json",

  "permission": {
    "read": "allow",
    "list": "allow",
    "glob": "allow",
    "grep": "allow",

    "edit": "ask",

    "bash": {
      "ls *": "allow",
      "Get-ChildItem *": "allow",
      "pwd *": "allow",
      "Get-Location *": "allow",
      "tree *": "allow",

      "cat *": "allow",
      "Get-Content *": "allow",
      "head *": "allow",
      "tail *": "allow",

      "find *": "allow",
      "rg *": "allow",
      "grep *": "allow",
      "Select-String *": "allow",

      "Test-Path *": "allow",
      "Get-Command *": "allow",
      "Resolve-Path *": "allow",
      "Split-Path *": "allow",
      "Join-Path *": "allow",
      "ConvertFrom-Json *": "allow",
      "ConvertTo-Json *": "allow",
      "Select-Object *": "allow",
      "Where-Object *": "allow",
      "ForEach-Object *": "allow",
      "Sort-Object *": "allow",
      "Group-Object *": "allow",
      "Measure-Object *": "allow",
      "New-Item *": "allow",
      "Remove-Item *": "allow",
      "Rename-Item *": "allow",
      "Copy-Item *": "allow",
      "Move-Item *": "allow",
      "Set-Content *": "allow",
      "Add-Content *": "allow",
      "Out-File *": "allow",
      "Write-Output *": "allow",

      "git log *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git blame *": "allow",
      "git remote *": "allow",
      "git branch *": "allow",
      "git stash list *": "allow",
      "git stash show *": "allow",

      "git *": "ask",

      "python -m pip *": "ask",

      "python *": "allow",
      "python3 *": "allow",
      "uv *": "ask",

      "node *": "ask",
      "npm *": "ask",
      "pnpm *": "ask",
      "yarn *": "ask",

      "docker *": "ask",
      "kubectl *": "ask",

      "*": "ask"
    },

    "webfetch": "ask",
    "websearch": "ask",

    "external_directory": "ask",

    "task": "ask"
  }
}